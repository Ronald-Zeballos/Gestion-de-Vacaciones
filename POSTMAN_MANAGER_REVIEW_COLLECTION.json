          "raw": "{\n  \"pro_uid\": \"975459502691b8d12e10f23055859700\",\n  \"appUid\": \"{{appUid}}\",\n  \"appNumber\": \"{{appNumber}}\",\n  \"act_uid\": \"{{appUid}}\",\n  \"app_index\": 2,\n  \"dyn_uid\": \"544190433691b8d13dafd67075313256\",\n  \"var_firstname\": \"Juan\",\n  \"var_lastname\": \"Perez\",\n  \"var_mail\": \"ronaldzeballoscallejas@gmail.com\",\n  \"var_user_name\": \"{{username}}\",\n  \"var_type_request\": 1,\n  \"var_type_request_label\": \"Vacaciones\",\n  \"var_days_hours\": 1,\n  \"var_days_hours_label\": \"Dias\",\n  \"var_type_permission\": \"\",\n  \"var_type_permission_label\": \"\",\n  \"var_start_date\": \"2026-04-28\",\n  \"var_end_date\": \"2026-05-06\",\n  \"var_days_requested\": 7,\n  \"var_requester_comment\": \"visita familiar\",\n  \"var_reviewer\": \"Administrator admin\",\n  \"var_reviewer_user_name\": \"admin\",\n  \"var_reviewer_phone\": \"{{phone}}\"\n}"
