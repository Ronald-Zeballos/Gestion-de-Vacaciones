            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"pro_uid\": \"975459502691b8d12e10f23055859700\",\n  \"tas_uid\": \"876543635691b8d13344218031759267\",\n  \"variables\": [\n    {\n      \"userId\": \"9999\",\n      \"userName\": \"admin\",\n      \"firstName\": \"X\",\n      \"lastName\": \"Y\",\n      \"email\": \"x@y.com\",\n      \"reviewer\": \"Administrator admin\",\n      \"reviewerUserName\": \"admin\",\n      \"reviewerPhone\": \"{{phone}}\",\n      \"typeRequest\": 1,\n      \"daysHours\": 1,\n      \"typePermission\": 3,\n      \"reason\": \"Prueba para mostrar flujo completo\",\n      \"startDate\": \"14-04-2026\",\n      \"endDate\": \"15-04-2026\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/test-lurana-case?notifyManager=1",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "test-lurana-case"
